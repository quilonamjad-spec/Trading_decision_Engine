"""
=========================================================

Trade Decision Engine (TDE)

Replay Test

Purpose
-------
Integration test for the complete replay pipeline.

=========================================================
"""

import yfinance as yf

from engine.pipeline import Pipeline
from engine.replay import ReplayEngine


# -------------------------------------------------

SYMBOL = "RELIANCE.NS"

INTERVAL = "5m"

PERIOD = "5d"

REPLAY_START = "09:30"

REPLAY_END = "15:30"

# -------------------------------------------------

print("\nDownloading market data...")

df = yf.download(

    SYMBOL,

    period=PERIOD,

    interval=INTERVAL,

    progress=False

)

if df.empty:

    raise Exception("No market data downloaded.")

print(f"{len(df)} candles downloaded.")

# -------------------------------------------------

pipeline = Pipeline(verbose=False)

replay = ReplayEngine(

    pipeline,

    verbose=True

)

# -------------------------------------------------

timeline = replay.run(

    symbol=SYMBOL,

    df=df,

    start_time=REPLAY_START,

    end_time=REPLAY_END

)

# -------------------------------------------------

print()

print("=" * 80)

print("Replay Timeline")

print("=" * 80)

for item in timeline:

    print(

        f"{item['time']} | "

        f"{item['decision']:10} | "

        f"Score {item['trade_score']:3} | "

        f"Consensus {item['consensus']:3}"

    )

# -------------------------------------------------

print()

print("=" * 80)

print("Replay Summary")

print("=" * 80)

highest = max(

    timeline,

    key=lambda x: x["trade_score"]

)

print(f"Stock             : {SYMBOL}")

print(f"Replay Candles    : {len(timeline)}")

print(f"Highest Score     : {highest['trade_score']}")

print(f"Highest Decision  : {highest['decision']}")

print(f"Highest Time      : {highest['time']}")

print()

print("Final Decision")

print("---------------------------")

print(

    timeline[-1]["result"]["decision"]

)

print()

print("Final Explanation")

print("---------------------------")

print(

    timeline[-1]["result"]["explanation"]

)
